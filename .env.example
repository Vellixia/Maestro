# ── Provider API keys ─────────────────────────────────────────────────────────
# At least one provider key is required to route requests.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── SurrealDB ─────────────────────────────────────────────────────────────────
# Set when connecting to a remote SurrealDB instance (ws:// or wss://).
# Omit to use in-memory storage (state lost on restart).
SURREALDB_URL=ws://surrealdb:8000
DB_USER=root
DB_PASS=change-me-in-production

# ── Maestro server ────────────────────────────────────────────────────────────
PORT=3456
# Set to require API key authentication on all endpoints.
# REQUIRE_API_KEY=1
# Argon2 password hash (generate with: maestro hash-password <password>)
# PASSWORD_HASH=
JWT_SECRET=change-me-in-production

# ── Frontend ──────────────────────────────────────────────────────────────────
# Baked into the Next.js bundle at build time — must match the public API URL.
NEXT_PUBLIC_API_URL=http://localhost:3456

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info
# RUST_LOG=maestro=debug,tower_http=debug
